<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="it.univr.mokamintminer.gui.LoginController"
      spacing="20" alignment="CENTER" prefWidth="700" prefHeight="500" styleClass="main-container">


    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <Label text="Mokamint Desktop Miner" styleClass="title-label"/>
    <Label text="Benvenuto, seleziona la tua identità per iniziare" styleClass="subtitle-label"/>

    <Separator/>
    <VBox spacing="20" alignment="CENTER" styleClass="login-options-container">

        <!--BOTTONE GENERA UNA NUOVA IDENTITÀ-->
        <Button text="Genera Nuova Identità" onAction="#handleGenerateNew"
                maxWidth="Infinity" styleClass="button-secondary"/>

        <!--BOTTONE CARICA IDENTITÀ DA FILE-->
        <VBox spacing="10" alignment="CENTER">
            <Button text="Carica Identità da File" onAction="#handleShowLoadArea"
                    maxWidth="Infinity" styleClass="button-secondary"/>

            <VBox fx:id="loadJsonBox" spacing="10" visible="false" managed="false">
                <HBox spacing="10" alignment="CENTER">
                    <TextField fx:id="jsonPathField" promptText="Percorso file .json"
                               editable="false" HBox.hgrow="ALWAYS"/>
                    <Button text="Sfoglia..." onAction="#handleLoadJson"/>
                </HBox>

                <Button fx:id="loginJsonButton" text="Accedi all'Identità"
                        onAction="#handleFinalJsonLogin" visible="false" managed="false"
                        maxWidth="Infinity" styleClass="button-primary"/>
            </VBox>
        </VBox>

    </VBox>

    <!--BOTTONE CARICA IDENTITÀ CON LA MNEMONICA-->
    <VBox spacing="10" alignment="CENTER">
        <Button text="Ho già un' Identità" onAction="#toggleManualInput"
                maxWidth="Infinity" styleClass="button-secondary"/>

        <VBox fx:id="manualInputBox" visible="false" managed="false" spacing="10">
            <Label text="Inserisci le tue 12 parole (Mnemonica):" styleClass="label-small"/>
            <TextArea fx:id="mnemonicTextArea" prefHeight="80" wrapText="true"
                      promptText="es: apple banana cherry..."/>

            <Button text="Accedi con Mnemonica" onAction="#handleManualLogin"
                    maxWidth="Infinity" styleClass="button-primary"/>
        </VBox>
    </VBox>


</VBox>


