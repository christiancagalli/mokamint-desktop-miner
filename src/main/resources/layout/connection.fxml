<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import java.net.URL?>

<VBox spacing="25" alignment="TOP_CENTER" prefWidth="700" prefHeight="450"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.univr.mokamintminer.gui.ConnectionController"
      styleClass="main-container">

    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>

    <padding>
        <Insets top="45" right="50" bottom="40" left="50"/>
    </padding>

    <Label text="Configurazione Miner" styleClass="title-label">
        <VBox.margin>
            <Insets bottom="15"/>
        </VBox.margin>
    </Label>

    <VBox spacing="10" maxWidth="460">
        <Label text="Indirizzo Nodo (URI):" styleClass="label-standard"/>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ComboBox fx:id="uriComboBox"
                      editable="true"
                      HBox.hgrow="ALWAYS"
                      maxWidth="Infinity"
                      promptText="http://localhost:8080"/>
            <Button text="✕"
                    onAction="#handleRemoveUri"
                    minWidth="35.0"
                    styleClass="button-delete" />
        </HBox>
    </VBox>

    <VBox spacing="10" maxWidth="460">
        <Label text="Nome Identificativo Miner:" styleClass="label-standard"/>
        <TextField fx:id="minerNameField" promptText="Es. Miner Casa, Lipari Nodo 1..."/>
    </VBox>

    <Region minHeight="25" prefHeight="25" maxHeight="25" />

    <VBox spacing="12" alignment="CENTER" maxWidth="460">
        <Button text="Connetti al Nodo" onAction="#handleConnect"
                maxWidth="Infinity" prefHeight="46"
                styleClass="button-primary"/>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: #ff4444; -fx-font-weight: bold;" visible="false" />
    </VBox>

</VBox>